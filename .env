# PrakritiAI Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=PrakritiAI
APP_ENV=development
SECRET_KEY=your-secret-key-here-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Weather
OPENWEATHER_API_KEY=your-openweather-api-key

# Database
DATABASE_URL=postgresql://postgres:Meenal%401710@db.iwqcyjnuywigfovpnese.supabase.co:5432/postgres

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# RAG
FAISS_INDEX_PATH=rag/embeddings/faiss_index
KNOWLEDGE_BASE_PATH=rag/knowledge
